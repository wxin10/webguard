# =========================
# WebGuard production env example
# =========================
# Draft template only. Do not copy local development secrets into production.
# Keep service-specific values in the matching deployment environment store.

# -------------------------
# Global runtime
# -------------------------
APP_ENV=production
LOG_LEVEL=INFO

# Public origins used by deployment docs, release scripts, and operators.
FRONTEND_ORIGIN=https://webguard.example.com
WEB_APP_URL=https://webguard.example.com
API_BASE_URL=https://api.webguard.example.com
BACKEND_BASE_URL=https://api.webguard.example.com

# Published browser extension identity. Replace after Chrome/Edge store release.
EXTENSION_ID=<published-extension-id>
EXTENSION_ORIGIN=chrome-extension://<published-extension-id>

# -------------------------
# Backend security
# -------------------------
DEBUG=false
ENABLE_DEV_AUTH=false
ENABLE_RUNTIME_SCHEMA_GUARD=false

# Generate a unique high-entropy value. Minimum enforced length is 32 chars.
JWT_SECRET=<replace-with-strong-random-secret>
SECRET_ENCRYPTION_KEY=<replace-with-fernet-key>
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14
REFRESH_TOKEN_COOKIE_NAME=webguard_refresh_token
REFRESH_TOKEN_COOKIE_SECURE=true

PLUGIN_BINDING_CHALLENGE_EXPIRES_MINUTES=5
PLUGIN_REFRESH_TOKEN_EXPIRES_DAYS=30
DEFAULT_ADMIN_PASSWORD=<replace-with-initial-admin-password>
DEFAULT_GUEST_PASSWORD=<replace-with-initial-guest-password>

# Exact allowlist only. Wildcard CORS is rejected in production mode.
CORS_ORIGINS=https://webguard.example.com,chrome-extension://<published-extension-id>

# -------------------------
# Persistence
# -------------------------
# Production target database is PostgreSQL. Run Alembic migrations before app startup.
DATABASE_URL=postgresql://webguard:<password>@<postgres-host>:5432/webguard

# -------------------------
# Optional AI semantic analysis
# -------------------------
# Prefer configuring provider credentials in the Web admin AI configuration
# page. This environment key remains a fallback; empty key keeps rule-engine
# fallback available.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ENABLED=auto
DEEPSEEK_TIMEOUT_SECONDS=20

# -------------------------
# Frontend build
# -------------------------
VITE_API_BASE_URL=https://api.webguard.example.com
VITE_ENABLE_DEV_TOKEN_STORAGE=false

# -------------------------
# Extension release notes
# -------------------------
# The extension production package should use plugin binding tokens.
# Manual Web access-token fallback is development compatibility only.
