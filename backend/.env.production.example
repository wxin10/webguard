APP_NAME=WebGuard
APP_VERSION=1.0.0

# Production safety gate. The backend refuses unsafe combinations when DEBUG=False.
DEBUG=False
ENABLE_DEV_AUTH=False
ENABLE_RUNTIME_SCHEMA_GUARD=False

# Production target database is PostgreSQL.
# Run `alembic upgrade head` before starting application workers.
DATABASE_URL=postgresql://webguard:<password>@<postgres-host>:5432/webguard

# Exact production origins only. Do not use wildcard CORS.
CORS_ORIGINS=https://webguard.example.com,chrome-extension://<published-extension-id>

# Generate a unique high-entropy value and keep it in secret management.
JWT_SECRET=<replace-with-strong-random-secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14
REFRESH_TOKEN_COOKIE_NAME=webguard_refresh_token
REFRESH_TOKEN_COOKIE_SECURE=True

PLUGIN_BINDING_CHALLENGE_EXPIRES_MINUTES=5
PLUGIN_REFRESH_TOKEN_EXPIRES_DAYS=30

DEFAULT_ADMIN_PASSWORD=<replace-with-initial-admin-password>
DEFAULT_GUEST_PASSWORD=<replace-with-initial-guest-password>

MODEL_DIR=./models
MODEL_NAME=text_classifier

# Optional DeepSeek AI semantic analysis. Store the real key in secret
# management. Empty key keeps deterministic/rule/model detection available.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ENABLED=auto
DEEPSEEK_TIMEOUT_SECONDS=20
