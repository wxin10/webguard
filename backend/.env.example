APP_NAME=WebGuard
APP_VERSION=1.0.0
DEBUG=True
ENABLE_DEV_AUTH=True

# Local development database.
# Make sure the `webguard` database already exists in your local PostgreSQL.
DATABASE_URL=postgresql://webguard:webguard@127.0.0.1:5432/webguard

# Equivalent split fields. Used only when DATABASE_URL is empty.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=webguard
DB_USER=webguard
DB_PASSWORD=webguard
DB_CHARSET=utf8mb4

CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,chrome-extension://__EXTENSION_ID__
JWT_SECRET=replace_me_in_local_env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30

MODEL_DIR=./models
MODEL_NAME=text_classifier
