APP_NAME=WebGuard
APP_VERSION=1.0.0
DEBUG=True

# Local development database.
# Make sure the `webguard` database already exists in your local MySQL.
DATABASE_URL=mysql+pymysql://admin:adminadmin@127.0.0.1:3306/webguard?charset=utf8mb4

# Equivalent split fields. Used only when DATABASE_URL is empty.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=webguard
DB_USER=admin
DB_PASSWORD=adminadmin
DB_CHARSET=utf8mb4

MODEL_DIR=./models
MODEL_NAME=text_classifier
