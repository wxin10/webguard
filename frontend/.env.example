VITE_API_BASE_URL=http://127.0.0.1:8000

# Development compatibility only. When true, the Web app mirrors the current
# access token to localStorage key `webguard_dev_user` so it can be copied into
# the extension manual-token fallback. Keep false for production builds.
VITE_ENABLE_DEV_TOKEN_STORAGE=false

# For production builds, start from `frontend/.env.production.example`.
