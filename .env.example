# =========================
# WebGuard unified env example
# =========================
# This file is a top-level reference for local full-stack development.
# Prefer service-specific env files when available.
# Production values must never be committed.

# -------------------------
# Global runtime
# -------------------------
APP_ENV=development
LOG_LEVEL=INFO

# -------------------------
# Backend
# -------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# Target database direction: PostgreSQL
DATABASE_URL=postgresql://webguard:webguard@127.0.0.1:5432/webguard
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=replace_me_in_local_env
ENABLE_DEV_AUTH=true
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

MODEL_DIR=./models
MODEL_NAME=text_classifier
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,chrome-extension://__EXTENSION_ID__

# -------------------------
# Frontend
# -------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000

# -------------------------
# Extension
# -------------------------
EXTENSION_API_BASE_URL=http://127.0.0.1:8000
EXTENSION_WEB_BASE_URL=http://127.0.0.1:5173
EXTENSION_AUTO_SCAN_ENABLED=true
EXTENSION_AUTO_BLOCK_MALICIOUS=true
EXTENSION_WARN_ON_SUSPICIOUS=true
