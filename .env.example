# =========================
# WebGuard unified env example
# =========================
# This file is a top-level reference for local full-stack development.
# Prefer service-specific env files when available.
# Production values must never be committed. Use `.env.production.example`
# only as a production checklist template, not as a source of real secrets.

# -------------------------
# Global runtime
# -------------------------
APP_ENV=development
LOG_LEVEL=INFO

# -------------------------
# Backend
# -------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# Target database direction: PostgreSQL
DATABASE_URL=postgresql://webguard:webguard@127.0.0.1:5432/webguard
REDIS_URL=redis://127.0.0.1:6379/0

# Local-only placeholder. Production/staging must set a strong unique value
# with at least 32 characters; the backend refuses unsafe production settings.
JWT_SECRET=replace_me_in_local_env
ENABLE_DEV_AUTH=true
# Local compatibility guard for existing dev databases. Leave unset or true in
# local development. Production must set this to false and rely on Alembic.
ENABLE_RUNTIME_SCHEMA_GUARD=true
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14
REFRESH_TOKEN_COOKIE_NAME=webguard_refresh_token
# Local HTTP uses false. Production HTTPS must set this to true.
REFRESH_TOKEN_COOKIE_SECURE=false
PLUGIN_BINDING_CHALLENGE_EXPIRES_MINUTES=5
PLUGIN_REFRESH_TOKEN_EXPIRES_DAYS=30

MODEL_DIR=./models
MODEL_NAME=text_classifier

# Optional DeepSeek AI semantic risk analysis. Empty API key means the backend
# keeps working and falls back to rule/model detection only.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_ENABLED=auto
DEEPSEEK_TIMEOUT_SECONDS=20
# Local allowlist. Production must replace this with exact HTTPS Web origins
# and the published extension origin. Wildcard origins are not allowed.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,chrome-extension://__EXTENSION_ID__

# -------------------------
# Frontend
# -------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8000

# -------------------------
# Extension
# -------------------------
EXTENSION_API_BASE_URL=http://127.0.0.1:8000
EXTENSION_WEB_BASE_URL=http://127.0.0.1:5173
EXTENSION_AUTO_SCAN_ENABLED=true
EXTENSION_AUTO_BLOCK_MALICIOUS=true
EXTENSION_WARN_ON_SUSPICIOUS=true
