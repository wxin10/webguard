{
  "manifest_version": 3,
  "name": "WebGuard Malicious Site Guard",
  "version": "1.0.0",
  "description": "Browser-side execution agent for WebGuard malicious site detection, warning, and action sync.",
  "permissions": ["storage", "tabs", "notifications"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    },
    "default_popup": "dist/popup/popup.html"
  },
  "options_page": "dist/options/options.html",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/warning/warning.html"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
